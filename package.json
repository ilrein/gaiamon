{
  "name": "gaiamon",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Open-source, community-driven monster-collecting MMO in the browser",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler dev",
    "build": "vite build",
    "check": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "deploy": "pnpm build && wrangler deploy",
    "gen-art": "node --env-file=.env scripts/gen-art.mjs"
  },
  "dependencies": {
    "hono": "^4.8.0",
    "three": "^0.178.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "workerd"]
  },
  "devDependencies": {
    "@types/three": "^0.178.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "wrangler": "^4.107.0"
  }
}
