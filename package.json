{
  "name": "gaiamon",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Open-source, community-driven monster-collecting MMO in the browser",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler dev",
    "build": "vite build",
    "check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.worker.json",
    "test": "bun test src",
    "cf-typegen": "wrangler types",
    "deploy": "bun run build && wrangler deploy",
    "gen-art": "bun scripts/gen-art.mjs"
  },
  "trustedDependencies": ["esbuild", "sharp", "workerd"],
  "dependencies": {
    "hono": "^4.8.0",
    "three": "^0.178.0"
  },
  "devDependencies": {
    "@types/three": "^0.178.0",
    "playwright": "^1.61.1",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "wrangler": "^4.107.0"
  }
}
